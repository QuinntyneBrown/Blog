@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Blog Platform - API System Context Diagram

Person(admin, "Back-Office Admin", "Manages articles, digital assets, and settings via the SPA")
Person(reader, "Anonymous Reader", "Reads published blog posts via the public web app")

System(api, "Blog API System", "RESTful API serving both back-office and public site.\nEnforces conventions, auth, pagination, and error handling.")

SystemDb(db, "Database", "Stores articles, users, digital assets, and metadata")

Rel(admin, api, "Manages content", "HTTPS/JSON + JWT")
Rel(reader, api, "Reads published articles", "HTTPS/JSON")
Rel(api, db, "Reads/writes data", "SQL via EF Core")

@enduml
