                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "hn4d6",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Building Scalable Systems with Clean Architecture",
                  "lineHeight": 1.25,
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "800",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "9oMxB",
                  "fill": "$foreground-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "An exploration of how clean architecture principles help build maintainable, testable software systems.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "rectangle",
                  "id": "cV3z3",
                  "fill": "$border-subtle",
                  "width": "fill_container",
                  "height": 1
                },
                {
                  "type": "text",
                  "id": "8IqJa",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Software architecture is the foundation upon which all code is built. Without a clear architectural vision, projects devolve into tangled dependency graphs.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ukVH2",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Dependency Rule",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "JvFNu",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Source code dependencies must point inward. Your business rules don't know about the database or any external framework.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uoXJs",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Implementation in .NET",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "CeNtd",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "In a .NET solution, this manifests as separate projects: Domain, Application, Infrastructure, and API.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "foEgv",
                  "name": "xsDCB",
                  "width": "fill_container",
                  "fill": "$surface-elevated",
                  "cornerRadius": 8,
                  "stroke": {
                    "thickness": 1,
                    "fill": "$border-subtle"
                  },
                  "layout": "vertical",
                  "padding": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "Azw8E",
                      "fill": "$foreground-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "public class CreatePostHandler\n  : IRequestHandler<CreatePost>\n{\n  private readonly IBlogDbContext _ctx;\n\n  public async Task<PostDto> Handle(\n    CreatePost req,\n    CancellationToken ct)\n  {\n    var post = new Post(req.Title);\n    _ctx.Posts.Add(post);\n    await _ctx.SaveChangesAsync(ct);\n    return post.ToDto();\n  }\n}",
                      "lineHeight": 1.5,
                      "fontFamily": "Geist Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "gVw12",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Conclusion",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "fcYUF",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Clean Architecture is one of the most effective tools for building systems that survive changing requirements.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
