                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "An exploration of how clean architecture principles help build maintainable, testable software systems.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "rectangle",
