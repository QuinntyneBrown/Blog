                  "children": [
                    {
                      "type": "text",
                      "id": "nyh6I",
                      "fill": "$foreground-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "public class CreatePostHandler\n    : IRequestHandler<CreatePost, PostDto>\n{\n    private readonly IBlogDbContext _ctx;\n\n    public async Task<PostDto> Handle(\n        CreatePost req, CancellationToken ct)\n    {\n        var post = new Post(req.Title);\n        _ctx.Posts.Add(post);\n        await _ctx.SaveChangesAsync(ct);\n        return post.ToDto();\n    }\n}",
                      "lineHeight": 1.5,
                      "fontFamily": "Geist Mono",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
