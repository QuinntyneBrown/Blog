@page "/events"
@inject IConfiguration Configuration
@{
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    var siteUrl = Configuration["Site:SiteUrl"]?.TrimEnd('/') ?? "";
    ViewBag.Title = $"Events | {siteName}";
    ViewBag.Description = "Conferences, meetups, and community events — speaking engagements and appearances.";
    ViewBag.ActiveNav = "events";
    ViewBag.CanonicalUrl = $"{siteUrl}/events";
    Layout = "_Layout";
}

<div class="events-page">
    <section class="events-hero">
        <span class="events-tag">Events</span>
        <h1 class="events-title">Speaking &amp; Appearances</h1>
        <p class="events-desc">Conferences, meetups, and community events where you can catch me speaking about software architecture and modern .NET development.</p>
    </section>
    <section class="events-section">
        <div class="events-section-header">
            <h2 class="events-section-title">Upcoming</h2>
        </div>
        <div class="events-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--foreground-tertiary)">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <p>No upcoming events at the moment. Check back soon for new speaking engagements.</p>
        </div>
    </section>
    <section class="events-section">
        <div class="events-section-header">
            <h2 class="events-section-title">Past Events</h2>
        </div>
        <div class="events-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--foreground-tertiary)">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <p>No past events recorded yet.</p>
        </div>
    </section>
</div>

@section Head {
    <link rel="canonical" href="@(Configuration["Site:SiteUrl"]?.TrimEnd('/'))/events" />
}
