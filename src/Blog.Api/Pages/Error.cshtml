@page
@model Blog.Api.Pages.ErrorModel
@{
    ViewBag.Title = "Error | Quinn Brown";
    Layout = "_Layout";
}

<div class="not-found">
    <div class="not-found-number">@Model.StatusCode</div>
    <h1 class="not-found-title">Something went wrong</h1>
    <p class="not-found-desc">An unexpected error occurred. Please try again.</p>
    <a href="/" class="btn-primary">Back to home</a>
</div>
