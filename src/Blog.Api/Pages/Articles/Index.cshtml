@page "/articles"
@model Blog.Api.Pages.Articles.ArticlesIndexModel
@inject IConfiguration Configuration
@{
    ViewBag.Title = $"Articles | {Configuration["Site:SiteName"] ?? "Quinn Brown"}";
    ViewBag.ActiveNav = "articles";
    ViewBag.CanonicalUrl = $"{Configuration["Site:SiteUrl"]?.TrimEnd('/')}/articles";
}

<section class="hero" style="padding-bottom: 40px;">
    <h1 class="hero-title" style="font-size: 40px;">All Articles</h1>
    <p class="hero-subtitle">@Model.Articles.TotalCount article@(Model.Articles.TotalCount != 1 ? "s" : "") published</p>
</section>

<section class="articles-section">
    @if (Model.Articles.Items.Count == 0)
    {
        <div class="empty-state">
            <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <h2 class="empty-state-title">No articles yet</h2>
            <p class="empty-state-desc">Check back soon for new content.</p>
        </div>
    }
    else
    {
        <div class="article-grid">
            @foreach (var article in Model.Articles.Items)
            {
                <article class="article-card">
                    <div class="article-card-image">
                        @if (!string.IsNullOrEmpty(article.FeaturedImageUrl))
                        {
                            <img src="@article.FeaturedImageUrl" alt="@article.Title" loading="lazy" decoding="async" />
                        }
                        else
                        {
                            <div class="article-card-image-placeholder"></div>
                        }
                    </div>
                    <div class="article-card-body">
                        <div class="article-card-meta">
                            <time datetime="@article.DatePublished?.ToString("yyyy-MM-dd")">@article.DatePublished?.ToString("MMM d, yyyy")</time>
                            <span class="article-card-meta-dot"></span>
                            <span>@article.ReadingTimeMinutes min read</span>
                        </div>
                        <h2 class="article-card-title">@article.Title</h2>
                        <p class="article-card-abstract">@article.Abstract</p>
                        <a href="/articles/@article.Slug" class="article-card-link">
                            Read article
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </article>
            }
        </div>

        @if (Model.Articles.TotalPages > 1)
        {
            <nav class="pagination" aria-label="Pagination">
                @if (Model.Articles.HasPreviousPage)
                {
                    <a href="/articles?page=@(Model.CurrentPage - 1)" class="pagination-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                        Prev
                    </a>
                }
                @for (int i = 1; i <= Model.Articles.TotalPages; i++)
                {
                    <a href="/articles?page=@i" class="pagination-page @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
                @if (Model.Articles.HasNextPage)
                {
                    <a href="/articles?page=@(Model.CurrentPage + 1)" class="pagination-btn">
                        Next
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                }
            </nav>
        }
    }
</section>
