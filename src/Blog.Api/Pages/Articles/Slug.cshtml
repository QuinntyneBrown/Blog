@page "/articles/{slug}"
@model Blog.Api.Pages.Articles.ArticleDetailModel
@inject IConfiguration Configuration
@{
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    ViewBag.Title = $"{Model.Article?.Title} | {siteName}";
    ViewBag.Description = Model.Article?.Abstract;
    ViewBag.ActiveNav = "";
    var siteUrl = Configuration["Site:SiteUrl"]?.TrimEnd('/') ?? "";
    if (Model.Article != null)
    {
        ViewBag.CanonicalUrl = $"{siteUrl}/articles/{Model.Article.Slug}";
        ViewBag.OgType = "article";
        if (!string.IsNullOrEmpty(Model.Article.FeaturedImageUrl))
            ViewBag.OgImage = $"{siteUrl}{Model.Article.FeaturedImageUrl}";
        ViewBag.ArticlePublishedTime = Model.Article.DatePublished?.ToString("O");
        ViewBag.ArticleModifiedTime = Model.Article.UpdatedAt.ToString("O");
        ViewBag.ArticleAuthor = Configuration["Site:AuthorName"] ?? "Quinn Brown";
    }
}
@if (Model.Article == null)
{
    <div class="not-found">
        <div class="not-found-number">404</div>
        <h1 class="not-found-title">Article not found</h1>
        <p class="not-found-desc">This article doesn't exist or has been removed.</p>
        <a href="/articles" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to articles
        </a>
    </div>
}
else
{
    <article class="article-detail">
    @if (!string.IsNullOrEmpty(Model.Article.FeaturedImageUrl))
    {
        // Build WebP srcset from the pre-generated variants: {assetId}-{width}w.webp
        // FeaturedImageUrl is "/assets/{assetId}.ext" — strip prefix and extension to get the assetId.
        var heroFileName = Model.Article.FeaturedImageUrl.StartsWith("/assets/")
            ? Model.Article.FeaturedImageUrl.Substring("/assets/".Length)
            : System.IO.Path.GetFileName(Model.Article.FeaturedImageUrl);
        var heroAssetId = System.IO.Path.GetFileNameWithoutExtension(heroFileName);
        var heroWebpSrcset = string.Join(", ",
            new[] { 320, 640, 960, 1280, 1920 }
                .Select(w => $"/assets/{heroAssetId}-{w}w.webp {w}w"));
        <figure class="article-featured-image">
            <picture>
                <source type="image/webp"
                        srcset="@heroWebpSrcset"
                        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 960px, 1280px" />
                <img src="@Model.Article.FeaturedImageUrl" alt="@Model.Article.Title"
                     @(Model.Article.FeaturedImageWidth.HasValue ? $"width=\"{Model.Article.FeaturedImageWidth}\" height=\"{Model.Article.FeaturedImageHeight}\"" : "")
                     loading="eager" fetchpriority="high" decoding="async" />
            </picture>
        </figure>
    }
    else
    {
        <div class="article-featured-image"></div>
    }

    <div class="article-detail-inner">
        <div class="article-content-wrapper">
            <div class="article-meta">
                <time datetime="@Model.Article.DatePublished?.ToString("yyyy-MM-dd")">
                    @Model.Article.DatePublished?.ToString("MMMM d, yyyy")
                </time>
                <span class="article-meta-dot"></span>
                <span>@Model.Article.ReadingTimeMinutes min read</span>
            </div>
            <h1 class="article-title">@Model.Article.Title</h1>
            <p class="article-abstract">@Model.Article.Abstract</p>
            <div class="article-divider"></div>
            <div class="article-body">
                @Html.Raw(Model.Article.BodyHtml)
            </div>
            <div class="article-divider"></div>
            <a href="/articles" class="back-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to all articles
            </a>
        </div>
    </div>
    </article>

}
@section Head {
    @if (Model.Article != null)
    {
        var publisherLogoUrl = Configuration["Site:PublisherLogoUrl"] ?? $"{siteUrl}/images/logo.png";
        var imageJson = !string.IsNullOrEmpty(Model.Article.FeaturedImageUrl)
            ? $"\"image\": \"{siteUrl}{Model.Article.FeaturedImageUrl}\","
            : string.Empty;
        <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "Article",
            "headline": "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Article.Title))",
            "datePublished": "@Model.Article.DatePublished?.ToString("O")",
            "dateModified": "@Model.Article.UpdatedAt.ToString("O")",
            "description": "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Article.Abstract))",
            @Html.Raw(imageJson)
            "mainEntityOfPage": "@siteUrl/articles/@Model.Article.Slug",
            "author": {
                "@@type": "Person",
                "name": "@(Configuration["Site:AuthorName"] ?? "Quinn Brown")"
            },
            "publisher": {
                "@@type": "Organization",
                "name": "@(Configuration["Site:PublisherName"] ?? Configuration["Site:SiteName"] ?? "Quinn Brown")",
                "logo": {
                    "@@type": "ImageObject",
                    "url": "@Html.Raw(publisherLogoUrl)"
                }
            }
        }
        </script>
    }
}
