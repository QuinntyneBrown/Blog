@page "/admin/about"
@model Blog.Api.Pages.Admin.About.AdminAboutEditModel
@{
    ViewBag.AdminTitle = "About";
    ViewBag.AdminNav = "about";
    Layout = "/Pages/Admin/Shared/_AdminLayout.cshtml";
}

<div class="toolbar" data-testid="toolbar">
    <div class="toolbar-left">
        <h1 class="toolbar-title" style="font-size:18px" data-testid="toolbar-title">About</h1>
    </div>
    <div class="toolbar-right">
        <button type="submit" form="about-form" class="btn btn-primary" data-testid="save-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span>Save</span>
        </button>
    </div>
</div>

<form id="about-form" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="profileImageId" id="profile-image-id" value="@Model.AboutContent?.ProfileImageId" />
    <div class="editor-layout">
        <div class="editor-main">
            <div class="form-group">
                <label class="form-label">Heading</label>
                <input class="form-input" type="text" name="heading" value="@Model.AboutContent?.Heading" placeholder="About heading..." required data-testid="heading-input" />
                @if (ModelState["heading"]?.Errors.Count > 0)
                {
                    <span class="form-error">@ModelState["heading"]!.Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group" style="flex:1;display:flex;flex-direction:column">
                <label class="form-label">Body (Markdown)</label>
                <textarea class="form-textarea" name="body" style="flex:1;min-height:400px;font-family:var(--font-mono);font-size:14px;line-height:1.7" placeholder="Write your about content in Markdown..." data-testid="body-input">@Model.AboutContent?.Body</textarea>
            </div>
        </div>
        <aside class="editor-sidebar">
            <div>
                <div class="editor-sidebar-label">Settings</div>
                <div style="display:flex;flex-direction:column;gap:16px">
                    <div class="form-group">
                        <label class="form-label">Profile Image</label>
                        <img data-testid="profile-image-preview" id="profile-image-preview" class="featured-img-preview" style="@(string.IsNullOrEmpty(Model.AboutContent?.ProfileImageUrl) ? "display:none;" : "")margin-bottom:8px" src="@(Model.AboutContent?.ProfileImageUrl ?? "")" alt="Profile image preview" />
                        <button type="button" data-testid="remove-profile-image" id="remove-profile-image-btn" class="btn btn-secondary" style="@(string.IsNullOrEmpty(Model.AboutContent?.ProfileImageUrl) ? "display:none;" : "display:inline-flex;")margin-bottom:8px;font-size:12px;padding:4px 10px" onclick="removeProfileImage()">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            <span>Remove Image</span>
                        </button>
                        <div class="dropzone" style="height:160px;@(!string.IsNullOrEmpty(Model.AboutContent?.ProfileImageUrl) ? "display:none;" : "")" data-testid="profile-image-button" id="open-image-chooser">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            <div class="dropzone-text">Drop image or click</div>
                            <div class="dropzone-hint">Max 10 MB</div>
                        </div>
                    </div>
                    @if (Model.AboutContent != null)
                    {
                        <div style="padding-top:16px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:8px">
                            <div style="display:flex;justify-content:space-between;font-size:12px"><span style="color:var(--fg-tertiary)">Last Saved</span><span style="color:var(--fg-primary);font-family:var(--font-mono)" data-testid="updated-at">@Model.AboutContent.UpdatedAt.ToString("MMM d, yyyy")</span></div>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</form>

<div class="modal-overlay modal-hidden" id="image-chooser-modal" role="dialog" aria-label="Choose profile image">
    <div class="modal modal-lg">
        <div class="modal-header">
            <span class="modal-title">Choose Profile Image</span>
            <button type="button" class="btn-icon" onclick="closeImageChooser()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="dropzone" style="height:120px" data-testid="dropzone" id="chooser-dropzone">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                <div class="dropzone-text">Drop image or click to choose</div>
                <div class="dropzone-hint">JPEG, PNG, WebP, AVIF — Max 10 MB</div>
            </div>
            <input type="file" id="chooser-file-input" accept="image/jpeg,image/png,image/webp,image/avif" style="display:none" />
            <div data-testid="upload-error" id="upload-error" style="display:none;color:var(--destructive);font-size:13px;margin-top:8px"></div>
            <div id="file-info" style="display:none">
                <div class="file-info">
                    <img data-testid="upload-preview" id="upload-preview" alt="Upload preview" />
                    <div class="file-info-meta">
                        <div data-testid="file-name" id="file-name" style="font-size:13px;font-weight:500;color:var(--fg-primary)"></div>
                        <div data-testid="file-size" id="file-size" style="font-size:12px;color:var(--fg-tertiary)"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeImageChooser()">Cancel</button>
            <button type="button" class="btn btn-primary" id="upload-btn" onclick="uploadProfileImage()" disabled>Upload</button>
        </div>
    </div>
</div>

@section AdminScripts {
<script>
    var apiToken = document.querySelector('meta[name="api-token"]')?.content || '';
    var selectedFile = null;

    function removeProfileImage() {
        document.getElementById('profile-image-id').value = '';
        document.getElementById('profile-image-preview').style.display = 'none';
        document.getElementById('remove-profile-image-btn').style.display = 'none';
        document.getElementById('open-image-chooser').style.display = '';
    }

    document.getElementById('open-image-chooser').addEventListener('click', function () {
        document.getElementById('image-chooser-modal').classList.remove('modal-hidden');
    });

    document.getElementById('chooser-dropzone').addEventListener('click', function () {
        document.getElementById('chooser-file-input').click();
    });

    document.getElementById('chooser-file-input').addEventListener('change', function () {
        if (this.files.length > 0) previewFile(this.files[0]);
    });

    document.getElementById('chooser-dropzone').addEventListener('dragover', function (e) { e.preventDefault(); this.style.borderColor = 'var(--accent)'; });
    document.getElementById('chooser-dropzone').addEventListener('dragleave', function () { this.style.borderColor = ''; });
    document.getElementById('chooser-dropzone').addEventListener('drop', function (e) {
        e.preventDefault(); this.style.borderColor = '';
        if (e.dataTransfer.files.length > 0) previewFile(e.dataTransfer.files[0]);
    });

    function previewFile(file) {
        var allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/avif'];
        var errEl = document.getElementById('upload-error');
        if (!allowed.includes(file.type)) { errEl.textContent = 'Only JPEG, PNG, WebP, and AVIF files are allowed.'; errEl.style.display = ''; return; }
        if (file.size > 10 * 1024 * 1024) { errEl.textContent = 'File size must be under 10 MB.'; errEl.style.display = ''; return; }
        errEl.style.display = 'none';
        selectedFile = file;
        document.getElementById('upload-preview').src = URL.createObjectURL(file);
        document.getElementById('file-name').textContent = file.name;
        document.getElementById('file-size').textContent = (file.size / 1024).toFixed(1) + ' KB';
        document.getElementById('file-info').style.display = '';
        document.getElementById('upload-btn').disabled = false;
    }

    function closeImageChooser() {
        document.getElementById('image-chooser-modal').classList.add('modal-hidden');
        selectedFile = null;
        document.getElementById('file-info').style.display = 'none';
        document.getElementById('upload-btn').disabled = true;
        document.getElementById('upload-error').style.display = 'none';
    }

    function uploadProfileImage() {
        if (!selectedFile) return;
        var fd = new FormData();
        fd.append('file', selectedFile);
        document.getElementById('upload-btn').disabled = true;
        document.getElementById('upload-btn').textContent = 'Uploading…';
        fetch('/api/digital-assets', { method: 'POST', headers: { 'Authorization': 'Bearer ' + apiToken }, body: fd })
            .then(function (r) { if (!r.ok) throw new Error('Upload failed'); return r.json(); })
            .then(function (data) {
                var asset = data.data || data;
                document.getElementById('profile-image-id').value = asset.digitalAssetId;
                document.getElementById('profile-image-preview').src = '/assets/' + asset.storedFileName;
                document.getElementById('profile-image-preview').style.display = '';
                document.getElementById('remove-profile-image-btn').style.display = 'inline-flex';
                document.getElementById('open-image-chooser').style.display = 'none';
                closeImageChooser();
            })
            .catch(function (err) {
                document.getElementById('upload-error').textContent = err.message;
                document.getElementById('upload-error').style.display = '';
            })
            .finally(function () {
                document.getElementById('upload-btn').disabled = false;
                document.getElementById('upload-btn').textContent = 'Upload';
            });
    }
</script>
}
