@page "/admin/articles/create"
@model Blog.Api.Pages.Admin.Articles.AdminArticleCreateModel
@{
    ViewBag.AdminTitle = "New Article";
    ViewBag.AdminNav = "articles";
    Layout = "/Pages/Admin/Shared/_AdminLayout.cshtml";
}

<div class="toolbar" data-testid="toolbar">
    <div class="toolbar-left">
        <a href="/admin/articles" class="btn-icon" data-testid="toolbar-back-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </a>
        <h1 class="toolbar-title" data-testid="toolbar-title">New Article</h1>
        <span class="badge badge-draft" data-testid="toolbar-badge">Draft</span>
    </div>
    <div class="toolbar-right">
        <button type="submit" form="create-form" class="btn btn-primary" data-testid="create-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <span>Create</span>
        </button>
    </div>
</div>

<form id="create-form" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="featuredImageId" id="featured-image-id-input" value="" />
    <div class="editor-layout">
        <div class="editor-main">
            <div class="form-group">
                <label class="form-label">Title</label>
                <input class="form-input" type="text" name="title" placeholder="Article title..." required />
                @if (ModelState["title"]?.Errors.Count > 0)
                {
                    <span class="form-error">@ModelState["title"]!.Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group">
                <label class="form-label">Abstract</label>
                <textarea class="form-textarea" name="abstract" rows="3" placeholder="A brief summary..."></textarea>
            </div>
            <div class="form-group" style="flex:1;display:flex;flex-direction:column">
                <label class="form-label">Body (Markdown)</label>
                <textarea class="form-textarea" name="body" style="flex:1;min-height:400px;font-family:var(--font-mono);font-size:14px;line-height:1.7" placeholder="Write your article in Markdown..."></textarea>
            </div>
        </div>
        <aside class="editor-sidebar">
            <div class="editor-sidebar-label">Article Settings</div>
            <div class="form-group">
                <label class="form-label">Featured Image</label>
                <div class="dropzone" style="height:160px;cursor:default" id="image-dropzone" data-testid="featured-image-dropzone" tabindex="0" role="button" aria-label="Open image upload dialog">
                    <svg id="featured-image-placeholder" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <div class="dropzone-text">No image selected</div>
                    <div class="dropzone-hint">Click "Choose Image" to upload</div>
                </div>
                <button type="button" class="btn btn-secondary" style="width:100%;margin-top:6px;font-size:12px" data-testid="featured-image-btn" id="featured-image-btn" onclick="document.getElementById('featured-image-dialog').showModal()">Choose Image</button>
                <button type="button" class="btn btn-secondary" style="width:100%;margin-top:6px;font-size:12px;display:none" data-testid="remove-image-btn" id="remove-image-btn">Remove Image</button>
            </div>
        </aside>
    </div>
</form>

<dialog id="featured-image-dialog" role="dialog" aria-labelledby="fid-title" style="border:1px solid var(--border);border-radius:var(--radius);background:var(--surface-card);color:var(--fg-primary);padding:0;max-width:480px;width:90%">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title" id="fid-title">Upload Featured Image</span>
            <button type="button" class="btn-icon" onclick="document.getElementById('featured-image-dialog').close()" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="dropzone" data-testid="dropzone" id="dialog-dropzone" style="height:140px;margin-bottom:12px">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <div class="dropzone-text">Drop image or click to select</div>
                <div class="dropzone-hint">JPEG, PNG, WebP, AVIF — Max 10 MB</div>
            </div>
            <input type="file" id="dialog-file-input" accept="image/jpeg,image/png,image/webp,image/avif" style="display:none" />
            <div data-testid="upload-preview" id="upload-preview" style="display:none;text-align:center;margin-bottom:12px">
                <img id="upload-preview-img" style="max-height:160px;max-width:100%;object-fit:contain;border-radius:4px" alt="Preview" />
                <div id="upload-file-name" data-testid="file-name" style="font-size:12px;color:var(--fg-secondary);margin-top:6px;font-family:var(--font-mono)"></div>
                <div id="upload-file-size" data-testid="file-size" style="font-size:11px;color:var(--fg-tertiary);font-family:var(--font-mono)"></div>
            </div>
            <div data-testid="upload-error" id="upload-error" style="display:none;color:var(--destructive);font-size:13px;margin-bottom:8px"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('featured-image-dialog').close()">Cancel</button>
            <button type="button" class="btn btn-primary" id="dialog-upload-btn">Upload</button>
        </div>
    </div>
</dialog>

@section AdminScripts {
<script>
    // Remove image button
    document.getElementById('remove-image-btn')?.addEventListener('click', () => {
        document.getElementById('featured-image-id-input').value = '';
        const dropzone = document.getElementById('image-dropzone');
        if (dropzone) {
            const preview = dropzone.querySelector('[data-testid="featured-image-preview"]');
            if (preview) preview.remove();
        }
        const removeBtn = document.getElementById('remove-image-btn');
        if (removeBtn) removeBtn.style.display = 'none';
    });

    // Image dropzone click/keyboard → open dialog
    const imageDropzone = document.getElementById('image-dropzone');
    imageDropzone?.addEventListener('click', () => {
        document.getElementById('featured-image-dialog')?.showModal();
    });
    imageDropzone?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            document.getElementById('featured-image-dialog')?.showModal();
        }
    });

    // Dialog dropzone → file input
    document.getElementById('dialog-dropzone')?.addEventListener('click', () => {
        document.getElementById('dialog-file-input').click();
    });

    // File selected → show preview
    document.getElementById('dialog-file-input')?.addEventListener('change', function () {
        const file = this.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            const previewDiv = document.getElementById('upload-preview');
            const previewImg = document.getElementById('upload-preview-img');
            const fileName = document.getElementById('upload-file-name');
            const fileSize = document.getElementById('upload-file-size');
            if (previewImg) previewImg.src = e.target.result;
            if (fileName) fileName.textContent = file.name;
            if (fileSize) fileSize.textContent = (file.size / 1024).toFixed(1) + ' KB';
            if (previewDiv) previewDiv.style.display = 'block';
            document.getElementById('dialog-dropzone').style.display = 'none';
        };
        reader.readAsDataURL(file);
    });

    // Upload button → AJAX POST to /api/digital-assets
    document.getElementById('dialog-upload-btn')?.addEventListener('click', async () => {
        const fileInput = document.getElementById('dialog-file-input');
        const file = fileInput?.files?.[0];
        if (!file) return;

        const errorEl = document.getElementById('upload-error');
        if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

        const token = document.querySelector('meta[name="api-token"]')?.content;
        const formData = new FormData();
        formData.append('file', file);

        try {
            const res = await fetch('/api/digital-assets', {
                method: 'POST',
                headers: token ? { 'Authorization': 'Bearer ' + token } : {},
                body: formData,
            });

            if (!res.ok) {
                const err = await res.text();
                if (errorEl) { errorEl.textContent = err || 'Upload failed.'; errorEl.style.display = 'block'; }
                return;
            }

            const asset = await res.json();
            document.getElementById('featured-image-id-input').value = asset.digitalAssetId;

            // Update editor dropzone with preview
            const editorDropzone = document.getElementById('image-dropzone');
            if (editorDropzone) {
                editorDropzone.innerHTML = `<img src="/assets/${asset.storedFileName}" id="featured-image-preview" data-testid="featured-image-preview" style="max-height:140px;max-width:100%;object-fit:contain;border-radius:4px" />`;
            }
            const removeBtn = document.getElementById('remove-image-btn');
            if (removeBtn) removeBtn.style.display = '';

            document.getElementById('featured-image-dialog').close();
            fileInput.value = '';
            const previewDiv = document.getElementById('upload-preview');
            if (previewDiv) previewDiv.style.display = 'none';
            document.getElementById('dialog-dropzone').style.display = '';
            showToast('success', 'Success', 'Image uploaded successfully.');
        } catch {
            if (errorEl) { errorEl.textContent = 'Upload failed. Please try again.'; errorEl.style.display = 'block'; }
        }
    });
</script>
}