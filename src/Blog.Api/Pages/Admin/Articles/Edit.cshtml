@page "/admin/articles/edit/{id:guid}"
@model Blog.Api.Pages.Admin.Articles.AdminArticleEditModel
@{
    ViewBag.AdminTitle = "Edit Article";
    ViewBag.AdminNav = "articles";
    Layout = "/Pages/Admin/Shared/_AdminLayout.cshtml";
}

<div class="toolbar" data-testid="toolbar">
    <div class="toolbar-left">
        <a href="/admin/articles" class="btn-icon" data-testid="toolbar-back-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </a>
        <h1 class="toolbar-title" data-testid="toolbar-title">Edit Article</h1>
        <span class="badge @(Model.Article?.Published == true ? "badge-published" : "badge-draft")" data-testid="toolbar-badge">
            @(Model.Article?.Published == true ? "Published" : "Draft")
        </span>
    </div>
    <div class="toolbar-right">
        <button type="submit" form="article-form" name="action" value="save" class="btn btn-secondary" data-testid="save-draft-btn">Save Draft</button>
        <button type="submit" form="article-form" name="action" value="publish" class="btn btn-primary" data-testid="publish-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span>@(Model.Article?.Published == true ? "Unpublish" : "Publish")</span>
        </button>
    </div>
</div>

<form id="article-form" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="version" value="@Model.Article?.Version" />
    <div class="editor-layout">
        <div class="editor-main">
            <div class="form-group">
                <label class="form-label">Title</label>
                <input class="form-input" type="text" name="title" value="@Model.Article?.Title" placeholder="Article title..." required />
                @if (!string.IsNullOrEmpty(Model.Article?.Slug))
                {
                    <div style="margin-top:4px;font-family:var(--font-mono);font-size:12px;color:var(--fg-tertiary)" data-testid="article-slug" aria-label="Article URL slug"><code>@Model.Article.Slug</code></div>
                }
            </div>
            <div class="form-group">
                <label class="form-label">Abstract</label>
                <textarea class="form-textarea" name="abstract" rows="3" placeholder="A brief summary of the article...">@Model.Article?.Abstract</textarea>
            </div>
            <div class="form-group" style="flex:1;display:flex;flex-direction:column">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                    <label class="form-label" style="margin:0">Body (Markdown)</label>
                    <div style="display:flex;gap:4px">
                        <button type="button" class="btn-icon" title="Bold" data-testid="toolbar-bold" onclick="insertMarkdown('**', '**')"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg></button>
                        <button type="button" class="btn-icon" title="Italic" data-testid="toolbar-italic" onclick="insertMarkdown('_', '_')"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
                        <button type="button" class="btn-icon" title="Heading" data-testid="toolbar-heading" onclick="insertMarkdown('\n## ', '')"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"/><path d="M4 18V6"/><path d="M20 18V6"/></svg></button>
                        <button type="button" class="btn-icon" title="Code" data-testid="toolbar-code" onclick="insertMarkdown('`', '`')"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></button>
                    </div>
                </div>
                <textarea class="form-textarea" id="body-textarea" name="body" style="flex:1;min-height:400px;font-family:var(--font-mono);font-size:14px;line-height:1.7" placeholder="Write your article in Markdown...">@Model.Article?.Body</textarea>
            </div>
        </div>
        <aside class="editor-sidebar">
            <div>
                <div class="editor-sidebar-label">Article Settings</div>
                <div style="display:flex;flex-direction:column;gap:16px">
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-select" name="statusSelect">
                            @if (Model.Article?.Published == false) { <option value="draft" selected>Draft</option> } else { <option value="draft">Draft</option> }
                            @if (Model.Article?.Published == true) { <option value="published" selected>Published</option> } else { <option value="published">Published</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Featured Image</label>
                        <div class="dropzone" style="height:160px;position:relative;cursor:default" id="image-dropzone" data-testid="featured-image-dropzone" tabindex="0" role="button" aria-label="Open image upload dialog">
                            @if (!string.IsNullOrEmpty(Model.Article?.FeaturedImageUrl))
                            {
                                <img src="@Model.Article.FeaturedImageUrl" id="featured-image-preview" data-testid="featured-image-preview" style="max-height:140px;max-width:100%;object-fit:contain;border-radius:4px" />
                            }
                            else
                            {
                                <svg id="featured-image-placeholder" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <div class="dropzone-text" id="featured-image-placeholder-text">No image selected</div>
                                <div class="dropzone-hint">Click "Choose Image" to upload</div>
                            }
                        </div>
                        <button type="button" class="btn btn-secondary" style="width:100%;margin-top:6px;font-size:12px" data-testid="featured-image-btn" id="featured-image-btn" onclick="document.getElementById('featured-image-dialog').showModal()">Choose Image</button>
                        <button type="button" class="btn btn-secondary" style="width:100%;margin-top:6px;font-size:12px;@(!string.IsNullOrEmpty(Model.Article?.FeaturedImageUrl) ? "" : "display:none")" data-testid="remove-image-btn" id="remove-image-btn">Remove Image</button>
                        <input type="hidden" name="featuredImageId" id="featured-image-id-input" value="@Model.Article?.FeaturedImageId" />
                        <input type="file" name="featuredImage" id="featured-image-input" accept="image/*" style="display:none" />
                    </div>
                    @if (Model.Article != null)
                    {
                        <div style="padding-top:16px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:8px">
                            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--fg-tertiary)">Reading time</span><span style="color:var(--fg-secondary);font-family:var(--font-mono)" data-testid="reading-time">@Model.Article.ReadingTimeMinutes min</span></div>
                            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--fg-tertiary)">Created</span><span style="color:var(--fg-secondary);font-family:var(--font-mono)" data-testid="created-at">@Model.Article.CreatedAt.ToString("MMM d, yyyy")</span></div>
                            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--fg-tertiary)">Updated</span><span style="color:var(--fg-secondary);font-family:var(--font-mono)" data-testid="updated-at">@Model.Article.UpdatedAt.ToString("MMM d, yyyy")</span></div>
                            @if (Model.Article.Published && Model.Article.DatePublished.HasValue)
                            {
                                <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--fg-tertiary)">Published</span><span style="color:var(--fg-secondary);font-family:var(--font-mono)" data-testid="date-published">@Model.Article.DatePublished.Value.ToString("MMM d, yyyy")</span></div>
                            }
                            <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:var(--fg-tertiary)">Version</span><span style="color:var(--fg-secondary);font-family:var(--font-mono)" data-testid="article-version">v@Model.Article.Version</span></div>
                        </div>
                    }
                </div>
                @if (Model.Article != null)
                {
                    <button type="button" class="btn btn-destructive" style="width:100%;margin-top:16px" data-testid="delete-btn" onclick="showDeleteModal()">Delete Article</button>
                }
            </div>
        </aside>
    </div>
</form>

@if (Model.Article != null)
{
    <dialog id="featured-image-dialog" role="dialog" aria-labelledby="fid-title" style="border:1px solid var(--border);border-radius:var(--radius);background:var(--surface-card);color:var(--fg-primary);padding:0;max-width:480px;width:90%">
        <div class="modal">
            <div class="modal-header">
                <span class="modal-title" id="fid-title">Upload Featured Image</span>
                <button type="button" class="btn-icon" onclick="document.getElementById('featured-image-dialog').close()" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="dropzone" data-testid="dropzone" id="dialog-dropzone" style="height:140px;margin-bottom:12px">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--fg-tertiary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <div class="dropzone-text">Drop image or click to select</div>
                    <div class="dropzone-hint">JPEG, PNG, WebP, AVIF — Max 10 MB</div>
                </div>
                <input type="file" id="dialog-file-input" accept="image/jpeg,image/png,image/webp,image/avif" style="display:none" />
                <div data-testid="upload-preview" id="upload-preview" style="display:none;text-align:center;margin-bottom:12px">
                    <img id="upload-preview-img" style="max-height:160px;max-width:100%;object-fit:contain;border-radius:4px" alt="Preview" />
                    <div id="upload-file-name" data-testid="file-name" style="font-size:12px;color:var(--fg-secondary);margin-top:6px;font-family:var(--font-mono)"></div>
                    <div id="upload-file-size" data-testid="file-size" style="font-size:11px;color:var(--fg-tertiary);font-family:var(--font-mono)"></div>
                </div>
                <div data-testid="upload-error" id="upload-error" style="display:none;color:var(--destructive);font-size:13px;margin-bottom:8px"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('featured-image-dialog').close()">Cancel</button>
                <button type="button" class="btn btn-primary" id="dialog-upload-btn">Upload</button>
            </div>
        </div>
    </dialog>
}

@if (Model.Article != null)
{
    <div class="modal-overlay modal-hidden" id="delete-modal" data-testid="modal">
        <div class="modal">
            <div class="modal-header">
                <span class="modal-title" data-testid="modal-header">Delete Article</span>
                <button class="btn-icon" data-testid="modal-close-btn" onclick="closeDeleteModal()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body" data-testid="modal-body">Delete "@Model.Article.Title"? This action cannot be undone.</div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-testid="modal-cancel-btn" onclick="closeDeleteModal()">Cancel</button>
                <form method="post" asp-page-handler="Delete" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Article.ArticleId" />
                    <input type="hidden" name="version" value="@Model.Article.Version" />
                    <button type="submit" class="btn btn-destructive" data-testid="modal-confirm-btn">Delete</button>
                </form>
            </div>
        </div>
    </div>
}

@section AdminScripts {
<script>
    // Featured image dropzone click/keyboard → open dialog
    const imageDropzone = document.getElementById('image-dropzone');
    imageDropzone?.addEventListener('click', () => {
        document.getElementById('featured-image-dialog')?.showModal();
    });
    imageDropzone?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            document.getElementById('featured-image-dialog')?.showModal();
        }
    });

    // Remove image button
    document.getElementById('remove-image-btn')?.addEventListener('click', () => {
        document.getElementById('featured-image-id-input').value = '';
        const preview = document.getElementById('featured-image-preview');
        const placeholder = document.getElementById('featured-image-placeholder');
        const placeholderText = document.getElementById('featured-image-placeholder-text');
        if (preview) preview.style.display = 'none';
        if (placeholder) placeholder.style.display = '';
        if (placeholderText) placeholderText.style.display = '';
        const removeBtn = document.getElementById('remove-image-btn');
        if (removeBtn) removeBtn.style.display = 'none';
    });

    // Dialog dropzone → file input
    document.getElementById('dialog-dropzone')?.addEventListener('click', () => {
        document.getElementById('dialog-file-input').click();
    });

    // File selected → show preview
    document.getElementById('dialog-file-input')?.addEventListener('change', function () {
        const file = this.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            const previewDiv = document.getElementById('upload-preview');
            const previewImg = document.getElementById('upload-preview-img');
            const fileName = document.getElementById('upload-file-name');
            const fileSize = document.getElementById('upload-file-size');
            if (previewImg) previewImg.src = e.target.result;
            if (fileName) fileName.textContent = file.name;
            if (fileSize) fileSize.textContent = (file.size / 1024).toFixed(1) + ' KB';
            if (previewDiv) previewDiv.style.display = 'block';
            document.getElementById('dialog-dropzone').style.display = 'none';
        };
        reader.readAsDataURL(file);
    });

    // Upload button → AJAX POST to /api/digital-assets
    document.getElementById('dialog-upload-btn')?.addEventListener('click', async () => {
        const fileInput = document.getElementById('dialog-file-input');
        const file = fileInput?.files?.[0];
        if (!file) return;

        const errorEl = document.getElementById('upload-error');
        if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

        const token = document.querySelector('meta[name="api-token"]')?.content;
        const formData = new FormData();
        formData.append('file', file);

        try {
            const res = await fetch('/api/digital-assets', {
                method: 'POST',
                headers: token ? { 'Authorization': 'Bearer ' + token } : {},
                body: formData,
            });

            if (!res.ok) {
                const err = await res.text();
                if (errorEl) { errorEl.textContent = err || 'Upload failed.'; errorEl.style.display = 'block'; }
                return;
            }

            const asset = await res.json();
            document.getElementById('featured-image-id-input').value = asset.digitalAssetId;

            // Update editor preview
            const editorDropzone = document.getElementById('image-dropzone');
            if (editorDropzone) {
                editorDropzone.innerHTML = `<img src="/assets/${asset.storedFileName}" id="featured-image-preview" data-testid="featured-image-preview" style="max-height:140px;max-width:100%;object-fit:contain;border-radius:4px" />`;
            }
            const removeBtn = document.getElementById('remove-image-btn');
            if (removeBtn) removeBtn.style.display = '';

            document.getElementById('featured-image-dialog').close();
            fileInput.value = '';
            const previewDiv = document.getElementById('upload-preview');
            if (previewDiv) previewDiv.style.display = 'none';
            document.getElementById('dialog-dropzone').style.display = '';
            showToast('success', 'Success', 'Image uploaded successfully.');
        } catch {
            if (errorEl) { errorEl.textContent = 'Upload failed. Please try again.'; errorEl.style.display = 'block'; }
        }
    });

    function insertMarkdown(before, after) {
        const ta = document.getElementById('body-textarea');
        const start = ta.selectionStart, end = ta.selectionEnd;
        const selected = ta.value.substring(start, end);
        ta.value = ta.value.substring(0, start) + before + selected + after + ta.value.substring(end);
        ta.focus();
        ta.selectionStart = start + before.length;
        ta.selectionEnd = end + before.length;
    }

    const deleteModal = document.getElementById('delete-modal');
    function showDeleteModal() { deleteModal?.classList.remove('modal-hidden'); }
    function closeDeleteModal() { deleteModal?.classList.add('modal-hidden'); }
    deleteModal?.addEventListener('click', e => { if (e.target === deleteModal) closeDeleteModal(); });
</script>
}