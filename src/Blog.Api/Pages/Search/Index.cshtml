@page "/search"
@model Blog.Api.Pages.Search.SearchIndexModel
@inject IConfiguration Configuration
@{
    Layout = "_Layout";
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    ViewBag.Title = Model.Query.Length > 0
        ? $"{Html.Encode(Model.Query)} — Search | {siteName}"
        : $"Search | {siteName}";
    ViewBag.Description = Model.Query.Length > 0
        ? $"Search results for '{Html.Encode(Model.Query)}'"
        : "Search published articles";
}

<style>
    .search-results-header {
        max-width: 860px;
        margin-inline: auto;
        padding: 48px 24px 24px;
    }

    .search-results-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: var(--foreground-primary);
        margin: 0 0 8px;
    }

    .search-results-header h1 q {
        quotes: "\201C" "\201D";
        font-style: normal;
    }

    .result-count {
        font-size: 14px;
        color: var(--foreground-secondary);
        margin: 0;
    }

    .search-results {
        max-width: 860px;
        margin-inline: auto;
        padding: 0 24px;
        list-style: none;
    }

    .result-card {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        padding: 24px 0;
        border-bottom: 1px solid var(--border-subtle);
    }

    .result-card-body {
        flex: 1;
        min-width: 0;
    }

    .result-title {
        font-size: 20px;
        font-weight: 600;
        margin: 0 0 8px;
        line-height: 1.4;
    }

    .result-title a {
        color: var(--foreground-primary);
        text-decoration: none;
    }

    .result-title a:hover {
        color: var(--accent-primary);
    }

    .result-title mark,
    .result-excerpt mark {
        background: transparent;
        color: var(--accent-primary);
        font-weight: 600;
    }

    .result-excerpt {
        font-size: 15px;
        color: var(--foreground-secondary);
        line-height: 1.6;
        margin: 0 0 12px;
    }

    .result-meta {
        display: flex;
        gap: 12px;
        font-size: 13px;
        color: var(--foreground-tertiary);
    }

    .result-type {
        font-weight: 500;
        color: var(--accent-primary);
    }

    .result-card-thumb {
        flex-shrink: 0;
        width: 180px;
    }

    .result-card-thumb img {
        width: 180px;
        height: 101px;
        object-fit: cover;
        border-radius: 4px;
        display: block;
    }

    .search-empty {
        max-width: 860px;
        margin-inline: auto;
        padding: 64px 24px;
        text-align: center;
    }

    .search-empty-icon {
        color: var(--foreground-tertiary);
        margin-bottom: 16px;
    }

    .empty-heading {
        font-size: 20px;
        font-weight: 600;
        color: var(--foreground-primary);
        margin: 0 0 8px;
    }

    .empty-heading q {
        quotes: "\201C" "\201D";
    }

    .empty-hint {
        font-size: 15px;
        color: var(--foreground-secondary);
        margin: 0 0 24px;
    }

    .search-page-pagination {
        max-width: 860px;
        margin-inline: auto;
        padding: 32px 24px;
    }

    @@media (max-width: 575px) {
        .result-card-thumb { display: none; }
        .search-results-header { padding-top: 32px; }
    }
</style>

<main id="main-content">
    <section class="search-results-header">
        <h1>
            @if (Model.Query.Length > 0)
            {
                <span>Results for </span><q>@Model.Query</q>
            }
            else
            {
                <span>Search</span>
            }
        </h1>
        @if (!Model.IsEmpty && !string.IsNullOrWhiteSpace(Model.Query))
        {
            <p aria-live="polite" class="result-count">
                @Model.Results.TotalCount result@(Model.Results.TotalCount == 1 ? "" : "s")
            </p>
        }
    </section>

    @if (Model.IsEmpty)
    {
        <section class="search-empty" aria-label="No results">
            <svg class="search-empty-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <p class="empty-heading">No results found for <q>@Model.Query</q></p>
            <p class="empty-hint">Try different keywords or fewer terms.</p>
            <a href="/articles" class="btn btn-secondary">Browse all articles</a>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(Model.Query))
    {
        <ol class="search-results" aria-label="Search results">
            @foreach (var result in Model.Results.Items)
            {
                <li>
                    <article class="result-card" data-testid="search-result">
                        <div class="result-card-body">
                            <h2 class="result-title">
                                <a href="/articles/@result.Slug">@Html.Raw(result.TitleHighlighted)</a>
                            </h2>
                            <p class="result-excerpt">@Html.Raw(result.AbstractHighlighted)</p>
                            <footer class="result-meta">
                                <span class="result-type">Article</span>
                                <time datetime="@result.DatePublished?.ToString("yyyy-MM-dd")">
                                    @result.DatePublished?.ToString("MMMM d, yyyy")
                                </time>
                                <span class="result-reading-time">@result.ReadingTimeMinutes min read</span>
                            </footer>
                        </div>
                        @if (result.FeaturedImageUrl != null)
                        {
                            <div class="result-card-thumb">
                                <img src="@result.FeaturedImageUrl"
                                     alt=""
                                     loading="lazy"
                                     decoding="async"
                                     width="180" height="101" />
                            </div>
                        }
                    </article>
                </li>
            }
        </ol>

        @if (Model.Results.TotalPages > 1)
        {
            <div class="search-page-pagination">
                <nav aria-label="Search results pages" class="pagination">
                    @if (Model.Results.HasPreviousPage)
                    {
                        <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@(Model.CurrentPage - 1)"
                           rel="prev" class="pagination-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                            Prev
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn disabled" aria-disabled="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                            Prev
                        </span>
                    }

                    @for (int p = 1; p <= Model.Results.TotalPages; p++)
                    {
                        if (p == Model.CurrentPage)
                        {
                            <span class="pagination-page active" aria-current="page">@p</span>
                        }
                        else
                        {
                            <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@p"
                               class="pagination-page">@p</a>
                        }
                    }

                    @if (Model.Results.HasNextPage)
                    {
                        <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@(Model.CurrentPage + 1)"
                           rel="next" class="pagination-btn pagination-btn-next">
                            Next
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn pagination-btn-next disabled" aria-disabled="true">
                            Next
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        </span>
                    }
                </nav>
            </div>
        }
    }
</main>
