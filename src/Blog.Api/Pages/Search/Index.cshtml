@page "/search"
@model Blog.Api.Pages.Search.SearchIndexModel
@inject IConfiguration Configuration
@{
    Layout = "_Layout";
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    ViewBag.Title = Model.Query.Length > 0
        ? $"{Html.Encode(Model.Query)} — Search | {siteName}"
        : $"Search | {siteName}";
    ViewBag.Description = Model.Query.Length > 0
        ? $"Search results for '{Html.Encode(Model.Query)}'"
        : "Search published articles";
    var cspNonce = HttpContext.Items[Blog.Api.Middleware.SecurityHeadersMiddleware.CspNonceKey] as string ?? "";
}

<style nonce="@cspNonce">
    .search-hero {
        background: var(--surface-secondary);
        padding: 64px 96px 48px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .search-hero-label {
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        color: var(--foreground-tertiary);
        letter-spacing: 1px;
        text-transform: uppercase;
    }
    .search-hero-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        height: 56px;
        background: var(--surface-input);
        border: 2px solid var(--border-focus);
        border-radius: var(--radius-md);
        padding: 0 20px;
    }
    .search-hero-bar svg { flex-shrink: 0; color: var(--foreground-secondary); }
    .search-hero-input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        font-family: var(--font-body);
        font-size: 18px;
        color: var(--foreground-primary);
    }
    .search-hero-input::placeholder { color: var(--foreground-placeholder); }
    .search-hero-clear {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: var(--surface-elevated);
        border: none;
        border-radius: 6px;
        cursor: pointer;
        color: var(--foreground-secondary);
        flex-shrink: 0;
    }
    .search-hero-clear:hover { color: var(--foreground-primary); }
    .search-hero-count {
        font-size: 14px;
        color: var(--foreground-tertiary);
    }
    .search-filters-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 96px;
        background: var(--surface-primary);
        border-bottom: 1px solid var(--border-subtle);
    }
    .search-filter-label {
        font-size: 14px;
        color: var(--foreground-tertiary);
        white-space: nowrap;
    }
    .search-filter-tags {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        flex-wrap: wrap;
    }
    .search-filter-spacer {
        flex: 1;
        min-width: 8px;
    }
    .search-sort-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }
    .search-sort-label {
        font-size: 14px;
        color: var(--foreground-tertiary);
        white-space: nowrap;
    }
    .search-sort-dropdown {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--surface-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        color: var(--foreground-primary);
        cursor: pointer;
        outline: none;
        appearance: none;
        -webkit-appearance: none;
    }
    .search-sort-dropdown:focus { border-color: var(--border-focus); }
    .search-sort-select-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--surface-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: 6px;
        position: relative;
    }
    .search-sort-select-wrap select {
        background: none;
        border: none;
        outline: none;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        color: var(--foreground-primary);
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
        padding-right: 4px;
    }
    .search-sort-select-wrap svg { flex-shrink: 0; color: var(--foreground-secondary); pointer-events: none; }
    .search-tag {
        display: flex;
        align-items: center;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }
    .search-tag-active {
        background: var(--accent-primary);
        color: var(--foreground-inverse);
        font-weight: 600;
    }
    .search-tag-inactive {
        background: var(--surface-elevated);
        color: var(--foreground-secondary);
        border: 1px solid var(--border-subtle);
    }
    .search-tag-inactive:hover { border-color: var(--border-strong); color: var(--foreground-primary); }
    .search-content {
        background: var(--surface-primary);
        padding: 48px 96px;
        display: flex;
        flex-direction: column;
        gap: 48px;
    }
    .search-results-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .search-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        text-align: center;
        padding: 80px 24px;
        color: var(--foreground-secondary);
    }
    .search-empty-state svg { color: var(--border-strong); }
    /* LG: 992–1199px */
    @@media (max-width: 1199px) {
        .search-hero { padding: 48px 48px 40px; gap: 20px; }
        .search-hero-bar { height: 52px; gap: 12px; padding: 0 16px; }
        .search-filters-bar { padding: 14px 48px; }
        .search-filter-label { display: none; }
        .search-content { padding: 40px 48px; gap: 40px; }
        .search-results-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    }
    /* MD: 768–991px */
    @@media (max-width: 991px) {
        .search-hero { padding: 40px 32px 32px; gap: 16px; }
        .search-hero-bar { height: 48px; gap: 12px; padding: 0 14px; }
        .search-hero-label { font-size: 11px; }
        .search-hero-count { font-size: 13px; }
        .search-filters-bar { padding: 12px 32px; }
        .search-content { padding: 32px; }
        .search-results-grid { grid-template-columns: repeat(2, 1fr); }
    }
    /* SM: 576–767px */
    @@media (max-width: 767px) {
        .search-hero { padding: 32px 24px 24px; gap: 14px; }
        .search-hero-bar { height: 44px; gap: 10px; padding: 0 12px; }
        .search-hero-label { font-size: 11px; }
        .search-hero-count { font-size: 12px; }
        .search-filters-bar { padding: 10px 24px; }
        .search-content { padding: 24px; gap: 20px; }
        .search-results-grid { grid-template-columns: 1fr; }
        .search-sort-wrap { display: none; }
    }
    /* XS: ≤575px */
    @@media (max-width: 575px) {
        .search-hero { padding: 24px 16px 20px; gap: 12px; }
        .search-hero-label { font-size: 10px; }
        .search-hero-count { font-size: 12px; }
        .search-filters-bar { padding: 10px 16px; gap: 8px; overflow-x: auto; flex-wrap: nowrap; }
        .search-content { padding: 20px 16px; gap: 16px; }
    }
</style>

<section class="search-hero">
    <span class="search-hero-label">Search Results</span>
    <form action="/search" method="get" class="search-hero-bar" id="search-form">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="search" name="q" class="search-hero-input" placeholder="Search articles…"
               value="@Model.Query" autocomplete="off" spellcheck="false" maxlength="200" aria-label="Search articles" />
        @if (Model.Query.Length > 0)
        {
            <button type="submit" name="q" value="" class="search-hero-clear" aria-label="Clear search">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        }
    </form>
    @if (Model.Query.Length > 0 && !Model.IsEmpty)
    {
        <p class="search-hero-count" aria-live="polite">
            @Model.Results.TotalCount result@(Model.Results.TotalCount == 1 ? "" : "s") for &ldquo;@Model.Query&rdquo;
        </p>
    }
</section>

<div class="search-filters-bar">
    <span class="search-filter-label">Filter by:</span>
    <div class="search-filter-tags">
        <span class="search-tag search-tag-active">All</span>
    </div>
    <div class="search-filter-spacer" aria-hidden="true"></div>
    <div class="search-sort-wrap">
        <span class="search-sort-label">Sort:</span>
        <div class="search-sort-select-wrap">
            <select id="sort-select" name="sort" form="search-form" aria-label="Sort results">
                <option value="relevant" selected="@(Model.Sort == "relevant" || string.IsNullOrEmpty(Model.Sort) ? "selected" : null)">Most Relevant</option>
                <option value="newest" selected="@(Model.Sort == "newest" ? "selected" : null)">Newest First</option>
                <option value="oldest" selected="@(Model.Sort == "oldest" ? "selected" : null)">Oldest First</option>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
    </div>
</div>

<section class="search-content" aria-label="Search results">
    @if (string.IsNullOrWhiteSpace(Model.Query) || Model.IsEmpty)
    {
        <div class="search-empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            @if (Model.Query.Length > 0)
            {
                <p class="empty-heading">No results found for &ldquo;@Model.Query&rdquo;</p>
                <p class="empty-hint">Try different keywords or fewer terms.</p>
            }
            else
            {
                <p class="empty-heading">Search for articles</p>
                <p class="empty-hint">Enter a keyword above to find articles.</p>
            }
        </div>
    }
    else
    {
        <div class="search-results-grid" role="list">
            @foreach (var result in Model.Results.Items)
            {
                <article class="article-card" role="listitem" data-testid="search-result">
                    <div class="article-card-image">
                        @if (!string.IsNullOrEmpty(result.FeaturedImageUrl))
                        {
                            <img src="@result.FeaturedImageUrl" alt="@result.Title" loading="lazy" decoding="async" />
                        }
                        else
                        {
                            <div class="article-card-image-placeholder"></div>
                        }
                    </div>
                    <div class="article-card-body">
                        <div class="article-card-meta">
                            <time datetime="@result.DatePublished?.ToString("yyyy-MM-dd")">
                                @result.DatePublished?.ToString("MMM d, yyyy")
                            </time>
                            <span class="article-card-meta-dot"></span>
                            <span>@result.ReadingTimeMinutes min read</span>
                        </div>
                        <h2 class="article-card-title">@Html.Raw(result.TitleHighlighted)</h2>
                        <p class="article-card-abstract">@Html.Raw(result.AbstractHighlighted)</p>
                        <a href="/articles/@result.Slug" class="article-card-link">
                            Read article
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </article>
            }
        </div>

        @if (Model.Results.TotalPages > 1)
        {
            var sortParam = !string.IsNullOrEmpty(Model.Sort) && Model.Sort != "relevant" ? $"&sort={Uri.EscapeDataString(Model.Sort)}" : "";
            <nav aria-label="Search results pages" class="pagination">
                @if (Model.Results.HasPreviousPage)
                {
                    <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@(Model.CurrentPage - 1)@sortParam"
                       rel="prev" class="pagination-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                        Prev
                    </a>
                }
                else
                {
                    <span class="pagination-btn disabled" aria-disabled="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                        Prev
                    </span>
                }

                @for (int p = 1; p <= Model.Results.TotalPages; p++)
                {
                    if (p == Model.CurrentPage)
                    {
                        <span class="pagination-page active" aria-current="page">@p</span>
                    }
                    else
                    {
                        <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@p@sortParam" class="pagination-page">@p</a>
                    }
                }

                @if (Model.Results.HasNextPage)
                {
                    <a href="/search?q=@Uri.EscapeDataString(Model.Query)&page=@(Model.CurrentPage + 1)@sortParam"
                       rel="next" class="pagination-btn pagination-btn-next">
                        Next
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                }
                else
                {
                    <span class="pagination-btn pagination-btn-next disabled" aria-disabled="true">
                        Next
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                    </span>
                }
            </nav>
        }
    }
</section>

<script nonce="@cspNonce">
    (function () {
        var sel = document.getElementById('sort-select');
        if (sel) {
            sel.addEventListener('change', function () {
                var form = document.getElementById('search-form');
                if (form) form.submit();
            });
        }
    }());
</script>
