@page "/about"
@model Blog.Api.Pages.AboutModel
@inject IConfiguration Configuration
@{
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    var siteUrl = Configuration["Site:SiteUrl"]?.TrimEnd('/') ?? "";
    var authorName = Configuration["Site:AuthorName"] ?? "Quinn Brown";
    var authorTitle = Configuration["Site:AuthorTitle"] ?? "";
    var gitHubUrl = Configuration["Site:GitHubUrl"] ?? "";
    var twitterUrl = Configuration["Site:TwitterUrl"] ?? "";
    ViewBag.ActiveNav = "about";

    if (Model.About != null)
    {
        ViewBag.Title = $"{Model.About.Heading} | {siteName}";
        var plainText = System.Text.RegularExpressions.Regex.Replace(Model.About.BodyHtml ?? "", "<[^>]+>", " ");
        plainText = System.Text.RegularExpressions.Regex.Replace(plainText, @"\s+", " ").Trim();
        if (plainText.Length > 160) plainText = plainText[..157] + "...";
        ViewBag.Description = plainText;
        ViewBag.CanonicalUrl = $"{siteUrl}/about";
        ViewBag.OgType = "profile";
        if (!string.IsNullOrEmpty(Model.About.ProfileImageUrl))
            ViewBag.OgImage = $"{siteUrl}{Model.About.ProfileImageUrl}";
    }
    else
    {
        ViewBag.Title = $"About | {siteName}";
        ViewBag.Description = $"About {authorName}";
        ViewBag.CanonicalUrl = $"{siteUrl}/about";
        ViewBag.OgType = "profile";
    }
}

@if (Model.About == null)
{
    <div class="about-empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--foreground-tertiary, #71717A)">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
        </svg>
        <h1 class="about-empty-title">About</h1>
        <p class="about-empty-desc">Content coming soon.</p>
    </div>
}
else
{
    <article class="about-page">
        <section class="about-hero">
            <div class="about-hero-text">
                <span class="about-tag">About</span>
                <h1 class="about-heading">@Model.About.Heading</h1>
                @if (!string.IsNullOrEmpty(authorTitle))
                {
                    <p class="about-subtitle">@authorTitle</p>
                }
                @if (!string.IsNullOrEmpty(gitHubUrl) || !string.IsNullOrEmpty(twitterUrl))
                {
                    <div class="about-social">
                        @if (!string.IsNullOrEmpty(gitHubUrl))
                        {
                            <a href="@gitHubUrl" class="about-social-btn" target="_blank" rel="noopener noreferrer">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                GitHub
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(twitterUrl))
                        {
                            <a href="@twitterUrl" class="about-social-btn" target="_blank" rel="noopener noreferrer">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                                Twitter / X
                            </a>
                        }
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.About.ProfileImageUrl))
            {
                <div class="about-hero-photo">
                    <img src="@Model.About.ProfileImageUrl" alt="@Model.About.Heading" loading="eager" />
                </div>
            }
        </section>
        <section class="about-bio">
            <h2 class="about-bio-heading">Background</h2>
            <div class="about-body">
                @Html.Raw(Model.About.BodyHtml)
            </div>
        </section>
    </article>
}

@section Head {
    @if (Model.About != null)
    {
        var publisherLogoUrl = Configuration["Site:PublisherLogoUrl"] ?? $"{siteUrl}/images/logo.png";
        <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "ProfilePage",
            "mainEntity": {
                "@@type": "Person",
                "name": "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.About.Heading))"@if (!string.IsNullOrEmpty(Model.About.ProfileImageUrl)){<text>,
                "image": "@Html.Raw($"{siteUrl}{Model.About.ProfileImageUrl}")"</text>}
            },
            "url": "@siteUrl/about"
        }
        </script>
    }
    <link rel="canonical" href="@(Configuration["Site:SiteUrl"]?.TrimEnd('/'))/about" />
}
