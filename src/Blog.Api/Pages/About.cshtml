@page "/about"
@model Blog.Api.Pages.AboutModel
@inject IConfiguration Configuration
@{
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    ViewBag.Title = Model.AboutContent != null ? $"{Model.AboutContent.Heading} | {siteName}" : $"About | {siteName}";
    ViewBag.Description = Model.AboutContent != null ? Model.AboutContent.Heading : $"About {siteName}";
    ViewBag.ActiveNav = "about";
    var siteUrl = Configuration["Site:SiteUrl"]?.TrimEnd('/') ?? "";
    ViewBag.CanonicalUrl = $"{siteUrl}/about";
    ViewBag.OgType = "website";
    if (Model.AboutContent?.ProfileImageUrl != null)
    {
        ViewBag.OgImage = $"{siteUrl}{Model.AboutContent.ProfileImageUrl}";
    }
}

@if (Model.AboutContent == null)
{
    <section class="about-section" style="max-width:720px;margin:0 auto;padding:48px 24px">
        <h1 style="font-size:32px;font-weight:800;margin-bottom:16px">About</h1>
        <p style="color:var(--muted);font-size:16px;line-height:1.7">No about content has been published yet.</p>
    </section>
}
else
{
    <article class="about-section" style="max-width:720px;margin:0 auto;padding:48px 24px">
        @if (!string.IsNullOrEmpty(Model.AboutContent.ProfileImageUrl))
        {
            <div style="margin-bottom:32px;text-align:center">
                <img src="@Model.AboutContent.ProfileImageUrl" alt="@Model.AboutContent.Heading" style="max-width:200px;border-radius:50%;aspect-ratio:1/1;object-fit:cover" loading="eager" />
            </div>
        }
        <h1 style="font-size:32px;font-weight:800;margin-bottom:24px;line-height:1.2">@Model.AboutContent.Heading</h1>
        <div class="article-body" style="font-size:16px;line-height:1.8;color:var(--text)">
            @Html.Raw(Model.AboutContent.BodyHtml)
        </div>
    </article>
}
