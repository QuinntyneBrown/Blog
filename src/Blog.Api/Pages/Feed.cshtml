@page "/feed"
@inject IConfiguration Configuration
@{
    var siteName = Configuration["Site:SiteName"] ?? "Quinn Brown";
    ViewBag.Title = $"Follow via Feed | {siteName}";
    ViewBag.Description = $"Subscribe to {siteName}'s blog via RSS, Atom, or JSON Feed.";
    ViewBag.ActiveNav = "feed";
    ViewBag.CanonicalUrl = $"{Configuration["Site:SiteUrl"]?.TrimEnd('/')}/feed";
    Layout = "_Layout";
}

<div class="feed-page">
    <div class="feed-inner">
        <div class="feed-header">
            <span class="feed-tag">Subscribe</span>
            <h1 class="feed-title">Follow via Feed</h1>
            <p class="feed-subtitle">Stay up to date with new articles using your favorite feed reader.</p>
        </div>
        <div class="feed-cards">
            <div class="feed-card">
                <div class="feed-card-left">
                    <div class="feed-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                    </div>
                    <div>
                        <div class="feed-card-title">RSS 2.0 Feed</div>
                        <div class="feed-card-desc">/feed.xml — Compatible with all major feed readers</div>
                    </div>
                </div>
                <button type="button" class="feed-card-btn" onclick="copyFeedUrl('/feed.xml', this)">Copy URL</button>
            </div>
            <div class="feed-card">
                <div class="feed-card-left">
                    <div class="feed-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                    </div>
                    <div>
                        <div class="feed-card-title">Atom Feed</div>
                        <div class="feed-card-desc">/atom.xml — Standard Atom 1.0 format</div>
                    </div>
                </div>
                <button type="button" class="feed-card-btn" onclick="copyFeedUrl('/atom.xml', this)">Copy URL</button>
            </div>
            <div class="feed-card">
                <div class="feed-card-left">
                    <div class="feed-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    </div>
                    <div>
                        <div class="feed-card-title">JSON Feed</div>
                        <div class="feed-card-desc">/feed/json — For modern feed readers and apps</div>
                    </div>
                </div>
                <button type="button" class="feed-card-btn" onclick="copyFeedUrl('/feed/json', this)">Copy URL</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function copyFeedUrl(path, btn) {
        const url = window.location.origin + path;
        navigator.clipboard.writeText(url).then(() => {
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = orig; }, 2000);
        });
    }
</script>
}
