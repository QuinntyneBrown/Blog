@page "/404"
@{
    ViewBag.Title = "Page Not Found — Quinn Brown";
    Layout = "_Layout";
}

<div class="not-found">
    <div class="not-found-number">404</div>
    <h1 class="not-found-title">Page not found</h1>
    <p class="not-found-desc">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/articles" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to articles
    </a>
</div>
